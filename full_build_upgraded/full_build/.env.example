# Server configuration
HOST=0.0.0.0
PORT=8000

# Authentication (optional - if not set, no auth required)
# AUTH_TOKEN=your-secret-token-here

# Rate limiting
RATE_LIMIT_QPS=5
RATE_LIMIT_WINDOW=60

# CORS
CORS_ORIGINS=*

# Model configuration
PRIMARY_MODEL_URL=http://localhost:8000/v1/chat/completions
# BACKUP_MODEL_URL=http://localhost:8001/v1/chat/completions
# MODEL_API_KEY=your-api-key
MODEL_NAME=gpt-3.5-turbo

# Retrieval configuration
RETRIEVAL_MODE=disabled
# QDRANT_URL=http://qdrant:6333
# ES_URL=http://elasticsearch:9200
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Self-loop configuration
MAX_ROUNDS=3
CONFIDENCE_THRESHOLD=0.65

# Code execution (off by default for security)
CODE_EXEC=off
